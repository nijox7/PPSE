#NEON

SRC=src/
OBJ=obj/
FILES=$(OBJ)main.o $(OBJ)transmitter.o $(OBJ)receiver.o $(OBJ)gaussian.o
STATS_FILES=stats_$(OBJ)main.o $(OBJ)transmitter.o $(OBJ)receiver.o $(OBJ)gaussian.o
RECEIVER_FLAGS=#-O3 -march=native
MAIN_FLAGS=-lm
GAUSSIAN_FLAGS=-lm
CC=arm-linux-gnueabihf-gcc -mfpu=neon -static -O3


simulator:	$(FILES)
	$(CC) -o simulator $(FILES) $(MAIN_FLAGS)

$(OBJ)main.o: $(SRC)main.c $(SRC)transmitter.h $(SRC)receiver.h $(SRC)gaussian.h
	$(CC) -c $(SRC)main.c -o $(OBJ)main.o 

$(OBJ)transmitter.o: $(SRC)transmitter.c $(SRC)transmitter.h
	$(CC) -c $(SRC)transmitter.c -o $(OBJ)transmitter.o

$(OBJ)receiver.o: $(SRC)receiver.c $(SRC)receiver.h $(SRC)gaussian.h
	$(CC) -c $(SRC)receiver.c -o $(OBJ)receiver.o $(RECEIVER_FLAGS)

$(OBJ)gaussian.o: $(SRC)gaussian.c $(SRC)gaussian.h
	$(CC) -c $(SRC)gaussian.c -o $(OBJ)gaussian.o $(GAUSSIAN_FLAGS)

clean:
	rm $(OBJ)*.o

clear:
	rm $(OBJ)*.o simulator

stats: $(STATS_FILES)
	$(CC) -o simulator $(FILES) -lm

stats_$(OBJ)main.o: $(SRC)main.c $(SRC)transmitter.h $(SRC)receiver.h
	$(CC) -c $(SRC)main.c -o $(OBJ)main.o -DENABLE_STATS
